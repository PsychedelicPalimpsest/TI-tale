PUBLIC _first_rom_page
PUBLIC _gray_count
PUBLIC _working_light
PUBLIC _working_dark

PUBLIC grey_phase1_buff
PUBLIC grey_phase2_buff
PUBLIC grey_phase3_buff

defc _globals_start = $C000

defc _first_rom_page = _globals_start               ; 1 byte, first page

defc _gray_count = _first_rom_page + 1              ; 2 byte, a count of the times the greyscale routine has fired
defc _game_count = _gray_count +2                   ; 2 bytes

defc _grey_timing = _game_count + 2                  ; 1 byte
defc _grey_contrast = _grey_timing + 1                  ; 1 byte


; Map of user keys, see: https://web.archive.org/web/20240225131330/https://wikiti.brandonw.net/index.php?title=83Plus:Ports:01
defc _current_keymap = _grey_contrast + 1                 ; size 8 bytes
defc _last_keymap = _current_keymap + 8                   ; size 8 bytes

; Down, left, right, up
defc _nav_key_change = _last_keymap + 8                   ; size 1 byte


; Set where z88dk puts static variables, note that only the first page is allowed them
defc c_bss = $C100

defc screen_size = 768    ; 96 * 64/8


defc buffer_start  = $C500

defc _working_dark = buffer_start
defc _working_light  = _working_dark +  screen_size

defc grey_phase1_buff =  _working_light + screen_size
defc grey_phase2_buff =  grey_phase1_buff + screen_size
defc grey_phase3_buff =  grey_phase2_buff + screen_size

