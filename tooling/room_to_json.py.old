import requests, json, sys
from bs4 import BeautifulSoup as Soup

out = {'_comment': f"Auto generated by {sys.argv[0]}, edit at your own risk!"}
sp = Soup(requests.get("https://tomat.dev/undertale/rooms").text)

for tr in sp.find("tbody").find_all("tr"):
    tds = list(tr.find_all("td"))
    if not tds: continue
    
    out[int(tds[0].text)] = tds[1].text
    

print(json.dumps(out, indent=2))


